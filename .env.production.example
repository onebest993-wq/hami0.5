# Hami — Production environment (server + Vite build)
# Copy to hosting secrets / .env.production — NEVER commit real values.
#
# ── Vercel (Project → Settings → Environment Variables) ──
# Production + Preview: set ALL keys below. Redeploy after changes.
# Build-time (Vite): VITE_*  |  Runtime (API routes): no VITE_ prefix
#
# ── Supabase ──
# 1. Dashboard → SQL: run migrations in supabase/migrations/ (or `supabase db push`)
# 2. Copy URL + anon + service_role from Project Settings → API
# 3. Create Upstash Redis → paste WIFE_REDIS_REST_URL + WIFE_REDIS_REST_TOKEN
#
# Gate (local with .env loaded):
#   npm run gate:wife-production:env -- --prod --live --tests

NODE_ENV=production

# Production: no automatic guest lawyer session (require real login)
VITE_SHELL_AUTH_OPEN=false

# Client (Vite — safe for bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# HttpOnly session — JWT في cookie وليس localStorage (يتطلب SUPABASE_* server-side)
VITE_BFF_AUTH=true
# VITE_SENTRY_DSN=https://...@sentry.io/PROJECT

# Server BFF only — never prefix with VITE_
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_UPLOAD_BUCKET=your-bucket-id

# WIFE distributed stores (required for production)
WIFE_REDIS_REST_URL=https://YOUR.upstash.io
WIFE_REDIS_REST_TOKEN=...

# After staging verifies /api/kv-proxy and /api/comms-dispatcher:
WIFE_DISABLE_EDGE_KV_PROXY=true
WIFE_DISABLE_EDGE_COMMS_DISPATCHER=true

# Platform admin
ADMIN_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ADMIN_ACCESS_KEY=generate-64-char-random-secret

# Optional server Sentry for WIFE rejection telemetry
# SENTRY_DSN=https://...@sentry.io/PROJECT

# Production gate: npm run gate:wife-production -- --tests --e2e --live
# With local env files: node scripts/load-env-and-gate.mjs --prod --live --tests
