# Hami Legal System - Environment Variables
# نسخ هذا الملف إلى .env وتعبئة القيم

# Sentry - تتبع الأخطاء (اختياري)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# في التطوير: kv-proxy معطّل افتراضياً (تخزين محلي) — فعّل فقط عند الحاجة:
# VITE_ENABLE_KV_PROXY=true
# VITE_ENABLE_CLOUD_SYNC=true
# بعد تطبيق migration 023 (calendar_tombstones) على Supabase:
# VITE_ENABLE_CALENDAR_TOMBSTONES_CLOUD=true

# Supabase - يتم التعامل معه عبر src/utils/supabase/info.ts
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# BFF HttpOnly session — JWT في cookie وليس localStorage (يتطلب SUPABASE_* server-side)
# VITE_BFF_AUTH=true
# عند التفعيل: login/session/refresh يُرجع cryptoWrapCredential في RAM فقط (لتشفير التخزين المحلي)

# ─── WIFE Production (server-side — لا تضع service_role في VITE_*) ───
# NODE_ENV=production
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server/BFF only — never VITE_
# في التطوير بدون هذا المفتاح: المواد تُحفظ محلياً في data/dev-iraqi-laws.json
#
# Upstash Redis — إلزامي للإنتاج (nonce + rate limit + stolen-token موزّع)
# WIFE_REDIS_REST_URL=https://xxx.upstash.io
# WIFE_REDIS_REST_TOKEN=...
#
# بعد التحقق من /api/kv-proxy في staging:
# WIFE_DISABLE_EDGE_KV_PROXY=true   # Edge function → 410 Gone
# WIFE_DISABLE_EDGE_COMMS_DISPATCHER=true   # Edge SMS → 410 (use /api/comms-dispatcher)
#
# Storage uploads (Vault / Repository / Forum attachments) — server-side bucket:
# SUPABASE_UPLOAD_BUCKET=make-f09713ba
# Edge function env (Supabase dashboard → Functions → make-server):
# SUPABASE_SERVICE_ROLE_KEY=...
#
# Migrations required (supabase db push):
#   20260423000000_create_wife_nonce_store.sql
#   20260613000000_wife_token_sessions.sql
#   20260613000001_wife_csrf_store.sql
#   20260613000002_wife_storage_bucket_rls.sql
#   20260613000003_audit_logs_rls.sql
#   20260613000004_fix_privileged_roles_and_rls.sql
#
# Platform admin (profiles.role=admin or this UUID):
# ADMIN_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# للتطوير المحلي مع «الدخول كمدير أعلى» (افتراضي dev: admin-uuid-1 إن لم تُحدّد):
# ADMIN_UUID=admin-uuid-1
# Edge honeypot/diagnostics (no default — required in production):
# ADMIN_ACCESS_KEY=generate-a-long-random-secret
# Optional: webhook for WIFE rejection alerts (Slack/Discord/custom SIEM)
# WIFE_SECURITY_WEBHOOK_URL=https://hooks.example.com/wife-security

# Production template: see .env.production.example

# ─── تطوير / تجربة: فتح كل ميزات لوحة المحامي بدون تسجيل Supabase حقيقي ───
# افتراضي في npm run dev: مفعّل. عطّله بـ false لاختبار بوابات الضيف.
# VITE_SHELL_AUTH_OPEN=true
